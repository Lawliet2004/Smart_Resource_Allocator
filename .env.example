# Copy to .env and edit as needed. .env is gitignored.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sra
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sra

APP_ENV=dev

JWT_SECRET=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
