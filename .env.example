# Copy to .env and edit as needed. .env is gitignored.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sra
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sra

APP_ENV=dev
# Omit to derive from APP_ENV, or set explicitly to true/false.
# SESSION_COOKIE_SECURE=false

JWT_SECRET=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

MAX_FORM_BYTES=100000
MAX_FORM_FIELDS=200
MAX_INGEST_CHARS=5000
MATCHER_CANDIDATE_LIMIT=500
COORDINATOR_TASK_LIMIT=200
COORDINATOR_PENDING_LIMIT=200
APPLICANTS_LIMIT=200
ADMIN_LIST_LIMIT=200
VOLUNTEER_TASK_SCAN_LIMIT=500
VOLUNTEER_ASSIGNMENTS_LIMIT=300
TASK_TITLE_MAX_CHARS=255
